                <td>${Number(p.amount || 0).toFixed(2)}</td>
                <td>${p.currency || '-'}</td>
                <td>${gatewayLabel}</td>
                <td>${statusBadge}</td>
                <td><span class="text-secondary small">${p.transactionId || '-'}</span></td>
                <td><small class="text-muted">${date}</small></td>
                <td class="text-center" style="white-space: nowrap;">
                  <div class="d-inline-flex flex-wrap" style="gap: 4px;">
                    <button class="btn btn-sm btn-dark" title="Receipt" aria-label="Receipt" onclick="viewPaymentReceipt(${p.id})"><i class="fas fa-receipt"></i></button>
                    <button class="btn btn-sm btn-dark" title="Approve" aria-label="Approve" onclick="updatePaymentStatus(${p.id}, 'approved')"><i class="fas fa-check"></i></button>
                    <button class="btn btn-sm btn-dark" title="Hold" aria-label="Hold" onclick="updatePaymentStatus(${p.id}, 'pending')"><i class="fas fa-pause"></i></button>
                    <button class="btn btn-sm btn-dark" title="Block" aria-label="Block" onclick="updatePaymentStatus(${p.id}, 'blocked')"><i class="fas fa-ban"></i></button>
                  </div>
                </td>
              </tr>
            `;
          });
          $('#paymentsTableBody').html(rows);

          $('#paymentsTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 10,
            "language": currentLang === 'tr' ? {
              "search": "Ara:",
              "lengthMenu": "_MENU_ kayıt göster",
              "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
              "zeroRecords": "Eşleşen ödeme bulunamadı"
            } : {
              "search": "Search:",
              "lengthMenu": "Show _MENU_ entries",
              "info": "Showing _START_ to _END_ of _TOTAL_ entries",
              "zeroRecords": "No matching payments found"
            }
          });
          updateDashboardStats();
        },
        error: function(err) {
          console.error('Failed to load payments', err);
        }
      });
    };

    window.viewPaymentReceipt = function(id) {
      $.ajax({
        url: `/api/payments/${id}`,
        type: 'GET',
        success: function(payment) {
          const date = new Date(payment.createdAt).toLocaleString(currentLang === 'tr' ? 'tr-TR' : 'en-US');
          const currency = (payment.currency || '').toUpperCase();
          const amount = Number(payment.amount || 0);
          const formattedAmount = new Intl.NumberFormat(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
            style: 'currency',
            currency: currency || 'USD',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
          }).format(Number.isFinite(amount) ? amount : 0);
          const status = payment.status || '-';
          const statusBadgeClass = status === 'approved' ? 'success' : status === 'blocked' ? 'danger' : 'warning';
          const statusLabel = currentLang === 'tr'
            ? (status === 'approved' ? 'Onaylandı' : status === 'blocked' ? 'Engellendi' : 'Beklemede')
            : (status === 'approved' ? 'Approved' : status === 'blocked' ? 'Blocked' : 'Pending');
          const gateway = payment.gateway || 'Stripe';
          const receiptHtml = `
            <div class="modal fade receipt-modal" id="paymentReceiptModal" tabindex="-1" role="dialog">
              <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                  <div class="modal-header">
                    <div>
                      <div class="receipt-titleline">
                        <span class="receipt-logo-mark"><i class="fab fa-stripe"></i></span>
                        <div>
                          <h5 class="modal-title mb-0">${currentLang === 'tr' ? 'Ödeme Dekontu' : 'Payment Receipt'}</h5>
                          <div class="receipt-subtitle">${currentLang === 'tr' ? 'Stripe-style preview' : 'Stripe-style preview'}</div>
                        </div>
                      </div>
                    </div>
                    <button type="button" class="close receipt-close" data-dismiss="modal">&times;</button>
                  </div>
                  <div class="modal-body">
                    <div class="receipt-summary">
                      <div class="receipt-card">
                        <div class="receipt-logo">
                          <span class="receipt-logo-mark"><i class="fab fa-stripe"></i></span>
                          <span>Stripe</span>
                        </div>
                        <div class="receipt-kicker">${currentLang === 'tr' ? 'Toplam Tutar' : 'Amount Due'}</div>
                        <div class="receipt-amount">${formattedAmount}</div>
                        <div class="receipt-meta-line">${payment.userEmail || '-'}</div>
                        <div class="receipt-meta-line">${currentLang === 'tr' ? 'İşlem No:' : 'Transaction:'} ${payment.transactionId || '-'}</div>
                        <div class="receipt-quick-row">
                          <span class="receipt-quick-chip"><i class="fas fa-lock"></i> Secure</span>
                          <span class="receipt-quick-chip"><i class="fas fa-bolt"></i> ${gateway}</span>
                        </div>
                      </div>
                      <div class="receipt-side">
                        <div class="receipt-side-card">
                          <span class="receipt-side-label">${currentLang === 'tr' ? 'Durum' : 'Status'}</span>
                          <span class="badge badge-${statusBadgeClass} px-3 py-2">${statusLabel}</span>
                        </div>
                        <div class="receipt-side-card">
                          <span class="receipt-side-label">${currentLang === 'tr' ? 'Oluşturulma' : 'Created'}</span>
                          <span class="receipt-side-value">${date}</span>
                        </div>
                        <div class="receipt-side-card">
                          <span class="receipt-side-label">${currentLang === 'tr' ? 'Abonelik Bitişi' : 'Subscription End'}</span>
                          <span class="receipt-side-value">${payment.subscriptionEndDate || '-'}</span>
                        </div>
                      </div>
                    </div>

                    <div class="receipt-details">
                      <div class="receipt-details-grid">
                        <div class="receipt-detail"><label>ID</label><strong>${payment.id}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Kullanıcı ID' : 'User ID'}</label><strong>${payment.userId}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'E-posta' : 'Email'}</label><strong>${payment.userEmail || '-'}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Ürün' : 'Product'}</label><strong>${payment.productId}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Tutar' : 'Amount'}</label><strong>${formattedAmount}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Para Birimi' : 'Currency'}</label><strong>${currency || '-'}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'İşlem ID' : 'Transaction ID'}</label><strong>${payment.transactionId || '-'}</strong></div>
                        <div class="receipt-detail"><label>UUID</label><strong>${payment.uuid || '-'}</strong></div>
                        <div class="receipt-detail"><label>IP</label><strong>${payment.ip || '-'}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Konum' : 'Location'}</label><strong>${payment.location || '-'}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Gateway' : 'Gateway'}</label><strong>${gateway}</strong></div>
                        <div class="receipt-detail"><label>${currentLang === 'tr' ? 'Durum Kodu' : 'Status Code'}</label><strong>${status}</strong></div>
                      </div>
                    </div>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-dismiss="modal">${currentLang === 'tr' ? 'Kapat' : 'Close'}</button>
                  </div>
                </div>
              </div>
            </div>`;

          $('#paymentReceiptModal').remove();
          $('body').append(receiptHtml);
          $('#paymentReceiptModal').modal('show');
        },
        error: function(xhr) {
          alert(xhr.responseJSON ? xhr.responseJSON.message : 'Unable to load receipt.');
        }
      });
    };

    window.updatePaymentStatus = function(id, status) {
      const labels = {
        approved: currentLang === 'tr' ? 'Bu ödemeyi onaylamak istediğinize emin misiniz?' : 'Approve this payment?',
        blocked: currentLang === 'tr' ? 'Bu ödemeyi engellemek istediğinize emin misiniz?' : 'Block this payment?',
        pending: currentLang === 'tr' ? 'Bu ödemeyi beklemeye almak istediğinize emin misiniz?' : 'Put this payment on hold?'
      };
      if (!confirm(labels[status] || 'Continue?')) return;

      $.ajax({
        url: `/api/payments/${id}/status`,
        type: 'PATCH',
        contentType: 'application/json',
        data: JSON.stringify({ status }),
        success: function() {
          loadPayments();
        },
        error: function(xhr) {
          alert(xhr.responseJSON ? xhr.responseJSON.message : 'Unable to update payment status.');
        }
      });
    };

    // Notifications Section Functions
    window.loadNotifications = function() {
      if ($.fn.DataTable.isDataTable('#notificationsTable')) {
        $('#notificationsTable').DataTable().destroy();
      }

      $.ajax({
        url: '/api/notifications',
        type: 'GET',
        success: function(notifications) {
          let rows = '';
          notifications.forEach(n => {
            const date = new Date(n.createdAt).toLocaleDateString(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
              hour: '2-digit',
              minute: '2-digit'
            });
            const typeBadge = `<span class="badge badge-${n.type === 'danger' ? 'danger' : n.type === 'success' ? 'success' : n.type === 'warning' ? 'warning' : 'info'}">${n.type.toUpperCase()}</span>`;
            const deleteLabel = currentLang === 'tr' ? 'Sil' : 'Delete';
            
            rows += `
              <tr>
                <td><span class="badge badge-dark">${n.id}</span></td>
                <td><strong>${n.title}</strong></td>
                <td><span class="text-secondary small">${n.message}</span></td>
                <td>${typeBadge}</td>
                <td><code>${n.sentTo}</code></td>
                <td><small class="text-muted"><i class="far fa-calendar-alt mr-1"></i> ${date}</small></td>
                <td class="text-center" style="white-space: nowrap;">
                  <div class="d-inline-flex" style="gap: 4px;">
                    <button class="btn btn-sm btn-danger" onclick="deleteNotification(${n.id})"><i class="fas fa-trash"></i> ${deleteLabel}</button>
                  </div>
                </td>
              </tr>
            `;
          });
          $('#notificationsTableBody').html(rows);

          $('#notificationsTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 10,
            "language": currentLang === 'tr' ? {
              "search": "Ara:",
              "lengthMenu": "_MENU_ kayıt göster",
              "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
              "zeroRecords": "Eşleşen bildirim bulunamadı"
            } : {
              "search": "Search:",
              "lengthMenu": "Show _MENU_ entries",
              "info": "Showing _START_ to _END_ of _TOTAL_ entries",
              "zeroRecords": "No matching notifications found"
            }
          });
          updateDashboardStats();
        },
        error: function(err) {
          console.error('Failed to load notifications', err);
        }
      });
    };

    $('#sendNotificationForm').submit(function(e) {
      e.preventDefault();
      const payload = {
        title: $('#notifTitle').val(),
        message: $('#notifMessage').val(),
        type: $('#notifType').val(),
        sentTo: $('#notifSentTo').val()
      };

      $.ajax({
        url: '/api/notifications',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(payload),
        success: function() {
          $('#sendNotificationForm')[0].reset();
          $('#notifSentTo').val('all');
          loadNotifications();
        },
        error: function(xhr) {
          const msg = xhr.responseJSON ? xhr.responseJSON.message : 'Error sending notification';
          $('#notification-alert').html(`<div class="alert alert-danger">${msg}</div>`);
        }
      });
    });

    window.deleteNotification = function(id) {
      const confirmMsg = currentLang === 'tr' ? 'Bu bildirimi silmek istediğinize emin misiniz?' : 'Are you sure you want to delete this notification?';
      if (!confirm(confirmMsg)) return;

      $.ajax({
        url: `/api/notifications/${id}`,
        type: 'DELETE',
        success: function() {
          loadNotifications();
        },
        error: function(xhr) {
          alert(xhr.responseJSON ? xhr.responseJSON.message : 'Error deleting notification');
        }
      });
    };

    // Image Preview Modal Handler
    $(document).on('click', '.preview-trigger', function(e) {
      e.preventDefault();
      const imageUrl = $(this).attr('href') || $(this).attr('src');
      const title = $(this).attr('data-title') || 'Image Preview';
      $('#previewImageSrc').attr('src', imageUrl);
      $('#imagePreviewModalLabel').text(title);
      $('#imagePreviewModal').modal('show');
    });

    // Helper functions for Shadcn-like Offcanvas Sheets
    window.openOffcanvas = function(id) {
      if ($('#offcanvas-backdrop').length === 0) {
        $('body').append('<div id="offcanvas-backdrop" class="offcanvas-backdrop-sheet"></div>');
      }
      // Force repaint to make sure transition executes smoothly
      $('#offcanvas-backdrop').show().css('opacity');
      $('#offcanvas-backdrop').addClass('show');
      $(`#${id}`).addClass('show');
      $('body').css('overflow', 'hidden');
    };

    window.closeOffcanvas = function(id) {
      if (id === 'videoModal' && isVideoUploadInProgress) {
        warnVideoUploadInProgress();
        return;
      }
      $(`#${id}`).removeClass('show');
      if ($('.offcanvas-sheet.show').length === 0) {
        $('#offcanvas-backdrop').removeClass('show');
        setTimeout(() => {
          if (!$('#offcanvas-backdrop').hasClass('show')) {
            $('#offcanvas-backdrop').hide();
          }
        }, 200);
        $('body').css('overflow', '');
      }
    };

    // Close when clicking the backdrop
    $(document).on('click', '#offcanvas-backdrop', function() {
      $('.offcanvas-sheet.show').each(function() {
        closeOffcanvas($(this).attr('id'));
      });
    });

    // Close when clicking any element with data-dismiss="modal" inside an offcanvas
    $(document).on('click', '[data-dismiss="modal"]', function() {
      const $offcanvas = $(this).closest('.offcanvas-sheet');
      if ($offcanvas.length > 0) {
        closeOffcanvas($offcanvas.attr('id'));
      }
    });

    // Intercept bootstrap modal calls for form modals to use our premium offcanvas sheets
    const originalModal = $.fn.modal;
    $.fn.modal = function(action, ...args) {
      const id = this.attr('id');
      if (['editUserModal', 'categoryModal', 'storyModal', 'audioItemModal', 'productModal', 'musicItemModal', 'videoModal'].includes(id)) {
        if (action === 'show') {
          openOffcanvas(id);
        } else if (action === 'hide') {
          closeOffcanvas(id);
        }
        return this;
      }
      return originalModal.apply(this, [action, ...args]);
    };

  });
</script>

