    function uploadToS3WithProgress(uploadUrl, file, onProgress) {
      return new Promise((resolve, reject) => {
        const xhr = new XMLHttpRequest();
        xhr.open('PUT', uploadUrl, true);

        xhr.upload.onprogress = function(event) {
          if (event.lengthComputable && typeof onProgress === 'function') {
            const percent = Math.round((event.loaded / event.total) * 100);
            onProgress(percent, event.loaded, event.total);
          }
        };

        xhr.onload = function() {
          if (xhr.status >= 200 && xhr.status < 300) {
            if (typeof onProgress === 'function') {
              onProgress(100, file.size, file.size);
            }
            resolve();
          } else {
            console.error('S3 upload failed', xhr.status, xhr.responseText);
            reject(new Error('S3 upload failed: ' + xhr.status));
          }
        };

        xhr.onerror = function() {
          console.error('S3 upload network error', xhr.status, xhr.responseText);
          reject(new Error('S3 upload network error'));
        };

        xhr.send(file);
      });
    }

    async function uploadFileToPresignedUrl(file, presign, onProgress) {
      await uploadToS3WithProgress(presign.uploadUrl, file, onProgress);
      return presign.url;
    }

    $('#videoForm').submit(function(e) {
      e.preventDefault();
      const id = $('#videoId').val();
      const bannerFileInput = $('#videoVerticalBannerFile')[0];
      const videoFileInput = $('#videoFile')[0];
      const srtFileInput = $('#videoSrtFile')[0];
      const progressWrap = $('#videoUploadProgressWrap');
      const progressBar = $('#videoUploadProgressBar');
      const progressText = $('#videoUploadProgressText');

      if (!id) {
        if (!bannerFileInput.files.length && !$('#videoVerticalBannerUrl').val()) {
          alert('Please select a vertical banner file to upload or enter a URL.');
          return;
        }
        if (!videoFileInput.files.length && !$('#videoUrl').val()) {
          alert('Please select a video file to upload or enter a URL.');
          return;
        }
      }

      const url = id ? `/api/videos/${id}` : '/api/videos';
      const type = id ? 'PUT' : 'POST';

      progressWrap.show();
      progressBar.css('width', '0%');
      progressText.text('0%');
      setVideoUploadLock(true);

      const selectedFiles = [];
      if (bannerFileInput.files && bannerFileInput.files[0]) {
        selectedFiles.push({ fieldName: 'verticalBanner', file: bannerFileInput.files[0] });
      }
      if (videoFileInput.files && videoFileInput.files[0]) {
        selectedFiles.push({ fieldName: 'video', file: videoFileInput.files[0] });
      }
      if (srtFileInput.files && srtFileInput.files[0]) {
        selectedFiles.push({ fieldName: 'subtitleFile', file: srtFileInput.files[0] });
      }

      const submitMetadata = (payload) => {
        progressText.text('Saving video metadata...');
        return $.ajax({
          url,
          type,
          data: JSON.stringify(payload),
          processData: false,
          contentType: 'application/json',
          success: function() {
            progressBar.css('width', '100%');
            progressText.text('Upload complete 100%');
            setVideoUploadLock(false);
            $('#videoModal').modal('hide');
            loadVideos();
          },
          error: function(err) {
            console.error('Video metadata save failed', err.responseJSON || err.responseText || err.statusText || err);
            setVideoUploadLock(false);
            progressText.text('Video metadata could not be saved.');
            const message = err.responseJSON && err.responseJSON.message
              ? err.responseJSON.message
              : (err.responseText || 'Error saving video.');
            alert(String(message).replace(/<[^>]*>/g, ''));
          }
        });
      };

      const sendWithPresignedUploads = async () => {
        let videoUrl = $('#videoUrl').val();
        let verticalBannerUrl = $('#videoVerticalBannerUrl').val();
        let subtitleUrl = $('#videoSrtUrl').val();

        if (selectedFiles.length) {
          const presignResponse = await fetch('/api/videos/presign', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({
              files: selectedFiles.map(({ fieldName, file }) => ({
                name: fieldName,
                originalName: file.name,
                contentType: file.type || 'application/octet-stream'
              }))
            })
          });

          if (!presignResponse.ok) {
            const errorData = await presignResponse.json().catch(() => null);
            throw new Error(errorData?.message || 'Could not get presigned URL.');
          }

          const presignData = await presignResponse.json();
          const presigns = presignData.uploads || [];

          for (const entry of selectedFiles) {
            const presign = presigns.find(item => item.fieldName === entry.fieldName);
            if (!presign) {
              throw new Error(`Presigned URL eksik: ${entry.fieldName}`);
            }
            const label = entry.fieldName === 'video'
              ? 'Video uploading...'
              : entry.fieldName === 'verticalBanner'
                ? 'Banner uploading...'
                : 'Subtitle uploading...';
            const uploadedUrl = await uploadFileToPresignedUrl(entry.file, presign, (percent) => {
              progressWrap.show();
              progressBar.css('width', percent + '%');
              progressText.text(label + ' ' + percent + '%');
            });
            if (entry.fieldName === 'video') videoUrl = uploadedUrl;
            if (entry.fieldName === 'verticalBanner') verticalBannerUrl = uploadedUrl;
            if (entry.fieldName === 'subtitleFile') subtitleUrl = uploadedUrl;
          }

          progressWrap.show();
          progressBar.css('width', '100%');
          progressText.text('Upload complete 100%');
        }

        const payload = {
          title: $('#videoTitle').val(),
          slug: $('#videoSlug').val() || generateRandomSlug('video'),
          category: $('#videoCategory').val(),
          categoryId: $('#videoCategoryId').val() ? parseInt($('#videoCategoryId').val()) : '',
          isLocked: $('#videoIsLocked').val() === 'true',
          isPublished: $('#videoIsPublished').val() === 'true',
          orderIndex: parseInt($('#videoOrderIndex').val() || 0),
          verticalBanner: verticalBannerUrl,
          verticalBannerUrl: verticalBannerUrl,
          video: videoUrl,
          videoUrl: videoUrl,
          subtitleUrl: subtitleUrl
        };

        return submitMetadata(payload);
      };

      sendWithPresignedUploads().catch((error) => {
        setVideoUploadLock(false);
        progressWrap.hide();
        alert(String(error.message || error).replace(/<[^>]*>/g, ''));
      });
    });

