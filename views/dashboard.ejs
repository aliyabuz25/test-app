            <div class="col-md-6">
              <div class="form-group mb-2">
                <label for="storyDuration" class="font-weight-bold text-secondary" style="font-size: 13px;">Duration (e.g. 05:30)</label>
                <input type="text" class="form-control" id="storyDuration" placeholder="MM:SS">
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group mb-2">
                <label for="storyDurationSeconds" class="font-weight-bold text-secondary" style="font-size: 13px;">Duration (Seconds)</label>
                <input type="number" class="form-control" id="storyDurationSeconds" value="0">
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <div class="form-group mb-0">
                <label for="storyIsLocked" class="font-weight-bold text-secondary" style="font-size: 13px;">Access Level</label>
                <select class="form-control custom-select" id="storyIsLocked">
                  <option value="false" selected>🔓 Free Access</option>
                  <option value="true">🔒 Locked (Premium)</option>
                </select>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-group mb-0">
                <label for="storyIsPublished" class="font-weight-bold text-secondary" style="font-size: 13px;">Status</label>
                <select class="form-control custom-select" id="storyIsPublished">
                  <option value="true" selected>🟢 Published</option>
                  <option value="false">Draft</option>
                </select>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Text Card -->
      <div class="card mb-2 border-0 shadow-sm" style="border-radius: 8px;">
        <div class="card-body p-3">
          <h6 class="text-success font-weight-bold mb-3 border-bottom pb-2" style="font-size: 14px;">
            <i class="fas fa-file-alt mr-1"></i> Story Text / Transcript
          </h6>
          <div class="form-group mb-0">
            <textarea class="form-control" id="storyContentText" rows="5" placeholder="Type or paste the story transcript text here..." style="font-size: 13px; line-height: 1.5;"></textarea>
          </div>
        </div>
      </div>

    </div>
    <div class="offcanvas-footer-sheet bg-white border-top shadow-sm p-3 d-flex justify-content-end" style="gap: 8px;">
      <button type="button" class="btn btn-secondary" onclick="closeOffcanvas('storyModal')">
        <i class="fas fa-times mr-1"></i> Cancel
      </button>
      <button type="submit" class="btn btn-success">
        <i class="fas fa-save mr-1"></i> Save & Publish
      </button>
    </div>
  </form>
</div>

<!-- Audio Item Modal -->
<div class="offcanvas-sheet" id="audioItemModal">
  <div class="offcanvas-header-sheet bg-primary text-white">
    <h5 class="offcanvas-title font-weight-bold" id="audioItemModalLabel">Audio Item Info</h5>
