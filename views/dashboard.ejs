              pending: 'Pending',
              blocked: 'Blocked',
              failed: 'Failed',
              refunded: 'Refunded',
              cancelled: 'Cancelled'
            };
            const statusClass = statusMap[normalizedStatus] || 'warning';
            const statusBadge = `<span class="badge badge-${statusClass}">${statusLabelMap[normalizedStatus] || p.status}</span>`;
            const gatewayLabel = p.gateway || '-';
            rows += `
