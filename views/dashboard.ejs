      <div class="row">
        <div class="col-md-12">
          <div class="form-group">
            <label for="audioTitle" class="font-weight-bold">Title *</label>
            <input type="text" class="form-control" id="audioTitle" required>
          </div>
          <input type="hidden" id="audioSlug">
          <div class="form-group">
            <label for="audioCategory" class="font-weight-bold">Category Name *</label>
            <input type="text" class="form-control" id="audioCategory" required>
          </div>
          <div class="form-group">
            <label for="audioCategoryId" class="font-weight-bold">Category ID</label>
            <input type="number" class="form-control" id="audioCategoryId">
          </div>
          <div class="form-group">
            <label for="audioDuration" class="font-weight-bold">Duration String (e.g. 03:45)</label>
            <input type="text" class="form-control" id="audioDuration">
          </div>
          <div class="form-group">
            <label for="audioDurationSeconds" class="font-weight-bold">Duration Seconds</label>
            <input type="number" class="form-control" id="audioDurationSeconds" value="0">
          </div>
          <div class="form-group">
            <label for="audioImageFile" class="font-weight-bold">Image File</label>
            <input type="file" class="form-control-file" id="audioImageFile" accept="image/*">
            <input type="text" class="form-control mt-2" id="audioImage" placeholder="Or enter Image URL (S3, CDN...)">
            <div id="audioImagePreviewContainer" class="mt-2" style="display:none;">
              <small class="text-muted d-block mb-1">Current Image:</small>
              <img id="audioImagePreview" src="" style="max-height: 80px; border-radius: 4px;" class="border">
            </div>
          </div>
          <div class="form-group">
            <label for="audioUrlField" class="font-weight-bold">Audio URL</label>
            <input type="text" class="form-control" id="audioUrlField" placeholder="https://...">
          </div>
          <div class="form-group">
            <label for="audioAudioFile" class="font-weight-bold">Or Upload Audio File</label>
            <input type="file" class="form-control-file" id="audioAudioFile" accept="audio/*">
          </div>
          <div class="form-group">
            <label for="audioBadgeColor" class="font-weight-bold">Badge Color</label>
            <input type="text" class="form-control" id="audioBadgeColor" placeholder="#007bff">
          </div>
          <div class="form-group">
            <label for="audioIsLocked" class="font-weight-bold">Locked (Premium)</label>
            <select class="form-control" id="audioIsLocked">
              <option value="false" selected>Free</option>
              <option value="true">Locked</option>
            </select>
          </div>
          <div class="form-group">
            <label for="audioIsPublished" class="font-weight-bold">Published</label>
            <select class="form-control" id="audioIsPublished">
              <option value="true" selected>Published</option>
              <option value="false">Draft</option>
            </select>
          </div>
          <div class="form-group">
            <label for="audioOrderIndex" class="font-weight-bold">Order Index</label>
            <input type="number" class="form-control" id="audioOrderIndex" value="0">
          </div>
        </div>
      </div>
    </div>
    <div class="offcanvas-footer-sheet">
      <button type="button" class="btn btn-secondary" onclick="closeOffcanvas('audioItemModal')">Close</button>
      <button type="submit" class="btn btn-primary">Save & Publish</button>
    </div>
  </form>
</div>

<!-- Product Modal -->
<div class="offcanvas-sheet" id="productModal">
  <div class="offcanvas-header-sheet bg-info text-white">
    <h5 class="offcanvas-title font-weight-bold" id="productModalLabel">Product Info</h5>
    <button type="button" class="close-btn text-white" onclick="closeOffcanvas('productModal')">&times;</button>
  </div>
  <form id="productForm" class="h-100 d-flex flex-column m-0">
    <input type="hidden" id="productId">
    <div class="offcanvas-body-sheet">
      <div class="row">
        <div class="col-md-12">
          <div class="form-group">
            <label for="prodTitle" class="font-weight-bold">Title *</label>
            <input type="text" class="form-control" id="prodTitle" required>
          </div>
          <div class="form-group">
            <label for="prodPrice" class="font-weight-bold">Price ($) *</label>
            <input type="number" step="0.01" class="form-control" id="prodPrice" required>
          </div>
          <div class="form-group">
            <label for="prodPriceString" class="font-weight-bold">Price Display String (e.g. $4.99)</label>
            <input type="text" class="form-control" id="prodPriceString">
          </div>
          <div class="form-group">
            <label for="prodImageFile" class="font-weight-bold">Image File</label>
            <input type="file" class="form-control-file" id="prodImageFile" accept="image/*">
            <input type="text" class="form-control mt-2" id="prodImage" placeholder="Or enter Image URL (S3, CDN...)">
            <div id="prodImagePreviewContainer" class="mt-2" style="display:none;">
              <small class="text-muted d-block mb-1">Current Image:</small>
              <img id="prodImagePreview" src="" style="max-height: 80px; border-radius: 4px;" class="border">
            </div>
          </div>
          <div class="form-group">
            <label for="prodDuration" class="font-weight-bold">Duration String (e.g. 1 Month)</label>
            <input type="text" class="form-control" id="prodDuration">
          </div>
          <div class="form-group">
            <label for="prodDurationSeconds" class="font-weight-bold">Duration Seconds</label>
            <input type="number" class="form-control" id="prodDurationSeconds" value="0">
          </div>
          <div class="form-group">
            <label for="prodDescription" class="font-weight-bold">Description</label>
            <textarea class="form-control" id="prodDescription" rows="3"></textarea>
          </div>
          <div class="form-group">
            <label for="prodOrderIndex" class="font-weight-bold">Order Index</label>
            <input type="number" class="form-control" id="prodOrderIndex" value="0">
          </div>
          <div class="form-group">
            <label for="prodIsPublished" class="font-weight-bold">Published</label>
            <select class="form-control" id="prodIsPublished">
              <option value="true" selected>Published</option>
              <option value="false">Draft</option>
            </select>
          </div>
        </div>
      </div>
    </div>
    <div class="offcanvas-footer-sheet">
      <button type="button" class="btn btn-secondary" onclick="closeOffcanvas('productModal')">Close</button>
      <button type="submit" class="btn btn-info">Save Product</button>
    </div>
  </form>
</div>

<!-- Music Item Modal -->
<div class="offcanvas-sheet" id="musicItemModal">
  <div class="offcanvas-header-sheet text-white" style="background-color: #6f42c1 !important;">
    <h5 class="offcanvas-title font-weight-bold" id="musicItemModalLabel">Music Item Info</h5>
    <button type="button" class="close-btn text-white" onclick="closeOffcanvas('musicItemModal')">&times;</button>
  </div>
  <form id="musicItemForm" class="h-100 d-flex flex-column m-0">
    <input type="hidden" id="musicItemId">
    <div class="offcanvas-body-sheet">
      <div class="row">
        <div class="col-md-12">
          <div class="form-group">
            <label for="musicTitle" class="font-weight-bold">Title *</label>
            <input type="text" class="form-control" id="musicTitle" required placeholder="e.g. Joyful Praise">
          </div>
          <div class="form-group">
            <label for="musicType" class="font-weight-bold">Type *</label>
            <select class="form-control" id="musicType" required>
              <option value="Background">Background</option>
              <option value="Instrumental">Instrumental</option>
              <option value="Meditation">Meditation</option>
              <option value="Vocal">Vocal</option>
              <option value="Christian Music">Christian Music</option>
              <option value="Hebrew Biblical Music">Hebrew Biblical Music</option>
            </select>
          </div>
          <div class="form-group">
            <label for="musicCategory" class="font-weight-bold">Category Name</label>
            <input type="text" class="form-control" id="musicCategory" placeholder="e.g. Nursery Rhymes">
          </div>
          <div class="form-group">
            <label for="musicCategoryId" class="font-weight-bold">Category ID</label>
            <input type="number" class="form-control" id="musicCategoryId" placeholder="e.g. 5">
          </div>
          <div class="form-group">
            <label for="musicImageFile" class="font-weight-bold">Image File *</label>
            <input type="file" class="form-control-file" id="musicImageFile" accept="image/*">
            <input type="text" class="form-control mt-2" id="musicImage" placeholder="Or enter Image URL">
            <div id="musicImagePreviewContainer" class="mt-2" style="display:none;">
              <small class="text-muted d-block mb-1">Current Image:</small>
              <img id="musicImagePreview" src="" style="max-height: 80px; border-radius: 4px;" class="border">
            </div>
          </div>
          <div class="form-group">
            <label for="musicAudioFile" class="font-weight-bold">Audio File *</label>
            <input type="file" class="form-control-file" id="musicAudioFile" accept="audio/*">
            <input type="text" class="form-control mt-2" id="musicUrlField" placeholder="Or enter Audio URL">
          </div>
        </div>
      </div>
    </div>
    <div class="offcanvas-footer-sheet">
      <button type="button" class="btn btn-secondary" onclick="closeOffcanvas('musicItemModal')">Close</button>
      <button type="submit" class="btn btn-success"><i class="fas fa-paper-plane mr-1"></i> Add & Publish</button>
    </div>
  </form>
</div>

<!-- Video Modal -->
<div class="offcanvas-sheet" id="videoModal">
  <div class="offcanvas-header-sheet bg-danger text-white">
    <h5 class="offcanvas-title font-weight-bold" id="videoModalLabel">Video Info</h5>
    <div class="offcanvas-header-actions">
      <button type="submit" form="videoForm" class="btn btn-light text-danger header-save-btn">
        <i class="fas fa-save mr-1"></i> Save &amp; Publish
      </button>
      <button type="button" class="close-btn text-white" onclick="closeOffcanvas('videoModal')">&times;</button>
    </div>
  </div>
  <form id="videoForm" class="h-100 d-flex flex-column m-0">
    <input type="hidden" id="videoId">
    <div class="offcanvas-body-sheet">
      <div class="upload-progress-wrap" id="videoUploadProgressWrap">
        <div class="upload-progress-label">
          <span>Uploading video</span>
          <span id="videoUploadProgressText">0%</span>
        </div>
        <div class="upload-progress-bar"><span id="videoUploadProgressBar"></span></div>
      </div>
      <div class="row">
        <div class="col-md-12">
          <div class="alert alert-light border mb-3" style="font-size: 13px; line-height: 1.45;">
            <strong>Quick use:</strong> Select a file and save. URL fields are only needed if you want to use an external link.
          </div>
          <div class="form-group">
            <label for="videoTitle" class="font-weight-bold">Title *</label>
            <input type="text" class="form-control" id="videoTitle" required placeholder="e.g. Bible Stories for Kids">
          </div>
          <input type="hidden" id="videoSlug">
          <div class="form-group">
            <label for="videoCategory" class="font-weight-bold">Category Name *</label>
            <input type="text" class="form-control" id="videoCategory" required placeholder="e.g. Kids Videos">
          </div>
          <div class="form-group">
            <label for="videoCategoryId" class="font-weight-bold">Category ID</label>
            <input type="number" class="form-control" id="videoCategoryId" placeholder="e.g. 1">
          </div>
          <div class="form-group">
            <label for="videoVerticalBannerFile" class="font-weight-bold">Vertical Banner <span class="text-muted">(preferred)</span></label>
            <input type="file" class="form-control-file" id="videoVerticalBannerFile" accept="image/*">
            <input type="text" class="form-control mt-2" id="videoVerticalBannerUrl" placeholder="Optional: paste banner URL">
            <small class="text-muted d-block mt-1">Selecting a file is the fastest option for the cover image.</small>
          </div>
          <div class="form-group">
            <label for="videoFile" class="font-weight-bold">Video File <span class="text-muted">(preferred)</span></label>
            <input type="file" class="form-control-file" id="videoFile" accept="video/*">
            <input type="text" class="form-control mt-2" id="videoUrl" placeholder="Optional: paste video URL">
            <small class="text-muted d-block mt-1">Direct file upload is recommended for large files.</small>
          </div>
          <div class="form-group">
            <label for="videoSrtFile" class="font-weight-bold">Subtitle File <span class="text-muted">(optional)</span></label>
            <input type="file" class="form-control-file" id="videoSrtFile" accept=".srt,.vtt,text/plain,text/vtt">
            <input type="text" class="form-control mt-2" id="videoSrtUrl" placeholder="Optional: paste subtitle URL">
          </div>
          <div class="video-form-card">
            <div class="form-group">
              <label for="videoIsPublished" class="font-weight-bold">Status</label>
              <select class="form-control" id="videoIsPublished">
                <option value="true" selected>Published</option>
                <option value="false">Draft</option>
              </select>
            </div>
            <div class="form-group">
              <label for="videoIsLocked" class="font-weight-bold">Access</label>
              <select class="form-control" id="videoIsLocked">
                <option value="false" selected>Free</option>
                <option value="true">Locked</option>
              </select>
            </div>
            <div class="form-group mb-0">
              <label for="videoOrderIndex" class="font-weight-bold">Order Index</label>
              <input type="number" class="form-control" id="videoOrderIndex" value="0">
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="offcanvas-footer-sheet">
      <button type="button" class="btn btn-secondary" onclick="closeOffcanvas('videoModal')"><i class="fas fa-times mr-1"></i> Close</button>
      <button type="submit" class="btn btn-danger"><i class="fas fa-save mr-1"></i> Save & Publish</button>
    </div>
  </form>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="imagePreviewModal" tabindex="-1" role="dialog" aria-labelledby="imagePreviewModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content" style="background: transparent; border: none; box-shadow: none;">
      <div class="modal-header" style="border: none; padding: 0 0 10px 0;">
        <h5 class="modal-title text-white font-weight-bold" id="imagePreviewModalLabel">Image Preview</h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close" style="font-size: 30px; line-height: 24px; opacity: 0.8;">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body p-0 text-center">
        <img id="previewImageSrc" src="" class="img-fluid rounded shadow-lg" style="max-height: 80vh; max-width: 100%; object-fit: contain;">
      </div>
    </div>
  </div>
</div>

</body>
</html>
