<script src="https://cdn.jsdelivr.net/npm/bs-custom-file-input/dist/bs-custom-file-input.min.js"></script>
<!-- AdminLTE App -->
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
<!-- DataTables & Plugins -->
<script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap4.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.2.9/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.2.9/js/responsive.bootstrap4.min.js"></script>

<script>
  // Dynamic Localization Dictionary fetched from Endpoint
  let locales = {};
  let currentLang = localStorage.getItem('lang') || 'en';

  function applyLanguage(lang) {
    currentLang = lang;
    localStorage.setItem('lang', lang);
    
    // Toggle active classes on dropdown buttons
    $('.lang-btn').removeClass('active');
    $(`.lang-btn[data-lang="${lang}"]`).addClass('active');

    // Update active flag in topbar
    const flagUrls = {
      en: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/us.svg',
      tr: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/tr.svg',
      de: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/de.svg',
      az: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/az.svg',
      es: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/es.svg',
      fr: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/fr.svg',
      it: 'https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/3.5.0/flags/4x3/it.svg'
    };
    $('#activeLangFlag').attr('src', flagUrls[lang] || flagUrls.en);
    $('#currentLangLabel').text(lang.toUpperCase());

    if (!locales[lang]) return;

    // Update translations
    $('[data-i18n]').each(function() {
      const key = $(this).attr('data-i18n');
      if (locales[lang] && locales[lang][key] !== undefined) {
        $(this).text(locales[lang][key]);
      }
    });

    // Update placeholders and custom fields
    $('#catalogSearchInput').attr('placeholder', locales[lang].searchPublications);
    $('#catalogName').attr('placeholder', locales[lang].publicationNameLabel);
    $('#catalogDescription').attr('placeholder', locales[lang].descriptionSummaryLabel || locales[lang].descriptionSummaryLabel);

    // Refresh Active Sidebar text
    const activeText = $('.nav-sidebar .nav-link.active[id]').find('p').attr('data-i18n');
    if (activeText && locales[lang][activeText]) {
      $('#pageTitle').text(locales[lang][activeText]);
      $('#breadcrumbActive').text(locales[lang][activeText]);
    }
  }

  function initLocalization() {
    $.ajax({
      url: '/api/locales',
      type: 'GET',
      success: function(data) {
        locales = data;
        applyLanguage(currentLang);
        loadCatalogs();
      },
      error: function(xhr) {
        console.error('Failed to load dictionary dynamically', xhr);
        // Fallback minimal dictionary
        locales = {
          en: {
            home: "Home", catalog: "Catalog", systemOperator: "System Operator", profile: "Profile", logout: "Logout",
            systemUser: "System User", dashboardOverview: "Dashboard Overview", catalogList: "Catalog List",
            addCatalogItem: "Add Catalog Item", securityShield: "Security Shield", totalCatalogItems: "Total Catalog Items",
            apiServiceStatus: "API Service Status", multipartUploadActive: "Multipart Upload Active", protectedLabel: "Protected",
            xssBruteforceShield: "XSS & Bruteforce Shield", viewDetails: "View Details", checkProtection: "Check Protection",
            uploadCover: "Upload Cover", securitySpecs: "Security Specs", welcomeTitle: "CMS Panel",
            welcomeText: "Manage content, users, payments, notifications, and media from a single admin panel.",
            registeredVisualPublications: "Registered Visual Publications", searchPublications: "Search...",
            id: "ID", publicationName: "Name", description: "Description", verticalCover: "Vertical Cover (3:4)",
            horizontalCover: "Horizontal Cover (16:9)", createdAt: "Created At", noPublicationsFound: "No publications found.",
            noPublicationsMatch: "No matching publications.", addNewVisualPublication: "Add Publication",
            publicationNameLabel: "Publication Name", descriptionSummaryLabel: "Description", verticalThumbnailCover: "Vertical Thumbnail Cover *",
            horizontalBannerCover: "Horizontal Banner Cover *", chooseVerticalImage: "Choose image...",
            chooseHorizontalImage: "Choose image...", verticalAspectRatio: "Vertical (3:4)", horizontalAspectRatio: "Horizontal (16:9)",
            noImageSelected: "No Image Selected", acceptsFormats: "Accepts formats.", saveUploadPublication: "Save & Upload",
            middlewareSecurityGuard: "Security Guard", helmetSecurity: "Helmet Security", helmetText: "Helmet protection.",
            rateLimiterShield: "Rate Limiter", rateLimiterText: "Rate limits active.", strictSanitizer: "Strict Sanitizer",
            strictSanitizerText: "XSS sanitizer active.", systemSchemaIntegration: "Schema specs", systemSchemaText: "Schema files."
          }
        };
        applyLanguage(currentLang);
        loadCatalogs();
      }
    });
  }

  function generateRandomSlug(prefix) {
    const randomPart = Math.random().toString(36).slice(2, 10);
    return `${prefix}-${Date.now().toString(36)}-${randomPart}`;
  }

  // Section switcher helper
  function showSection(sectionId, navLinkId) {
    // Hide all sections
    $('.content-section').addClass('d-none');
    // Show active section
    $(`#${sectionId}`).removeClass('d-none');
    
    // Update active nav-link
    $('.nav-sidebar .nav-link').removeClass('active');
    $(`#${navLinkId}`).addClass('active');
    
    // Auto-expand and highlight parent treeview if clicked a child item
    const $childLink = $(`#${navLinkId}`);
    $childLink.closest('.has-treeview').find('> .nav-link').addClass('active');

    // Update titles & breadcrumbs
    const activeText = $(`#${navLinkId}`).find('p').attr('data-i18n');
    if (activeText && locales[currentLang] && locales[currentLang][activeText]) {
      $('#pageTitle').text(locales[currentLang][activeText]);
      $('#breadcrumbActive').text(locales[currentLang][activeText]);
    } else {
      // Fallback for custom tabs that aren't localized
      const label = $(`#${navLinkId}`).find('p').text();
      $('#pageTitle').text(label);
      $('#breadcrumbActive').text(label);
    }
  }

  $(document).ready(function() {
    // Smooth Dark Mode Toggle logic
    const storedTheme = localStorage.getItem('theme') || 'light';
    if (storedTheme === 'dark') {
      $('body').addClass('dark-mode');
      $('#themeToggleIcon').removeClass('fa-moon').addClass('fa-sun');
    }

    $('#themeToggleBtn').on('click', function(e) {
      e.preventDefault();
      const body = $('body');
      const icon = $('#themeToggleIcon');
      
      // Rotate effect for the toggle icon
      icon.css('transform', 'rotate(360deg)');
      setTimeout(() => {
        icon.css('transform', 'rotate(0deg)');
      }, 300);

      if (body.hasClass('dark-mode')) {
        body.removeClass('dark-mode');
        icon.removeClass('fa-sun').addClass('fa-moon');
        localStorage.setItem('theme', 'light');
      } else {
        body.addClass('dark-mode');
        icon.removeClass('fa-moon').addClass('fa-sun');
        localStorage.setItem('theme', 'dark');
      }
    });

    // Initialize file input labels
    bsCustomFileInput.init();

    // Check token
    const token = localStorage.getItem('token');
    const user = JSON.parse(localStorage.getItem('user'));
    
    if (!token || !user) {
      window.location.href = '/login';
      return;
    }

    // Dynamic Avatar generation via UI-Avatars for clean standard alignment
    const firstName = user.firstName || 'Admin';
    const lastName = user.lastName || 'User';
    const cleanFirstName = $('<div/>').html(firstName).text(); // clean XSS tags visually
    const cleanUserFullName = `${cleanFirstName} ${lastName}`;
    const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(cleanUserFullName)}&background=17a2b8&color=fff&rounded=true&bold=true`;

    $('#sidebarAvatarImg').attr('src', avatarUrl);
    $('#userNavbarAvatarImg').attr('src', avatarUrl);
    $('#userDropdownAvatarImg').attr('src', avatarUrl);
    
    $('#userNameDisplay').text(cleanUserFullName);
    $('#userDropdownName').text(cleanUserFullName);
    $('#sidebarUserName').text(cleanUserFullName);

    // Update dashboard metrics
    function updateDashboardStats() {
      $.ajax({
        url: '/api/catalogs',
        type: 'GET',
        success: function(res) {
          $('#catalogsCount').text(res.length);
        }
      });
      $.ajax({
        url: '/api/users',
        type: 'GET',
        success: function(res) {
          $('#usersCount').text(res.length);
        }
      });
      $.ajax({
        url: '/api/payments',
        type: 'GET',
        success: function(res) {
          $('#paymentsCount').text(res.length);
        }
      });
      $.ajax({
        url: '/api/notifications',
        type: 'GET',
        success: function(res) {
          $('#notificationsCount').text(res.length);
        }
      });
    }

    // Section Switching Handlers
    $('#nav-stats').click(function(e) {
      e.preventDefault();
      showSection('stats-section', 'nav-stats');
      updateDashboardStats();
    });
    $('#nav-catalogs-list').click(function(e) {
      e.preventDefault();
      showSection('catalogs-list-section', 'nav-catalogs-list');
      loadCatalogs();
    });
    $('#nav-add-catalog').click(function(e) {
      e.preventDefault();
      showSection('add-catalog-section', 'nav-add-catalog');
    });
    $('#nav-categories').click(function(e) {
      e.preventDefault();
      showSection('categories-section', 'nav-categories');
      loadCategories();
    });
    $('#nav-stories').click(function(e) {
      e.preventDefault();
      showSection('stories-section', 'nav-stories');
      loadStories();
    });
    $('#nav-audio-items').click(function(e) {
      e.preventDefault();
      showSection('audio-items-section', 'nav-audio-items');
      loadAudioItems();
    });
    $('#nav-music-items').click(function(e) {
      e.preventDefault();
      showSection('music-items-section', 'nav-music-items');
      loadMusicItems();
    });
    $('#nav-products').click(function(e) {
      e.preventDefault();
      showSection('products-section', 'nav-products');
      loadProducts();
    });
    $('#nav-videos').click(function(e) {
      e.preventDefault();
      showSection('videos-section', 'nav-videos');
      loadVideos();
    });
    $('#nav-users').click(function(e) {
      e.preventDefault();
      showSection('users-section', 'nav-users');
      loadUsers();
    });
    $('#nav-admins').click(function(e) {
      e.preventDefault();
      showSection('admins-section', 'nav-admins');
      loadAdmins();
    });
    $('#nav-payments').click(function(e) {
      e.preventDefault();
      showSection('payments-section', 'nav-payments');
      loadPayments();
    });
    $('#nav-notifications').click(function(e) {
      e.preventDefault();
      showSection('notifications-section', 'nav-notifications');
      loadNotifications();
    });
    // Language switcher click events
    $('.lang-btn').click(function(e) {
      e.preventDefault();
      const lang = $(this).attr('data-lang');
      applyLanguage(lang);
      
      // Reload active tab data
      if ($('#nav-catalogs-list').hasClass('active')) loadCatalogs();
      if ($('#nav-categories').hasClass('active')) loadCategories();
      if ($('#nav-stories').hasClass('active')) loadStories();
      if ($('#nav-audio-items').hasClass('active')) loadAudioItems();
      if ($('#nav-music-items').hasClass('active')) loadMusicItems();
      if ($('#nav-products').hasClass('active')) loadProducts();
      if ($('#nav-videos').hasClass('active')) loadVideos();
      if ($('#nav-users').hasClass('active')) loadUsers();
      if ($('#nav-admins').hasClass('active')) loadAdmins();
      if ($('#nav-payments').hasClass('active')) loadPayments();
      if ($('#nav-notifications').hasClass('active')) loadNotifications();
      updateDashboardStats();
    });

    // Initialize Localization
    initLocalization();
    updateDashboardStats();

    // Logout function
    $('#logoutBtn').click(function(e) {
      e.preventDefault();
      localStorage.removeItem('token');
      localStorage.removeItem('user');
      window.location.href = '/login';
    });

    // Image Previews Event Listeners
    function readURL(input, imgElementId, placeholderId) {
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
          $(`#${imgElementId}`).attr('src', e.target.result).show();
          $(`#${placeholderId}`).hide();
        }
        reader.readAsDataURL(input.files[0]);
      }
    }

    $('#verticalImage').change(function() {
      readURL(this, 'verticalPreviewImg', 'verticalPlaceholder');
    });

    $('#horizontalImage').change(function() {
      readURL(this, 'horizontalPreviewImg', 'horizontalPlaceholder');
    });

    // Load Catalogs Function
    window.loadCatalogs = function() {
      // Destroy existing datatable instance if it exists to allow full re-population
      if ($.fn.DataTable.isDataTable('#catalogsTable')) {
        $('#catalogsTable').DataTable().destroy();
      }

      $.ajax({
        url: '/api/catalogs',
        type: 'GET',
        success: function(catalogs) {
          $('#catalogsCount').text(catalogs.length);
          let rows = '';
          
          catalogs.forEach(catalog => {
            const date = new Date(catalog.createdAt).toLocaleDateString(currentLang === 'tr' ? 'tr-TR' : 'en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric'
            });
            
            // Map uploaded local file or absolute CDN url
            const verticalURL = catalog.thumbnailVertical.startsWith('https://cdn.biblecms.com')
              ? '/uploads/' + catalog.thumbnailVertical.split('/').pop() 
              : catalog.thumbnailVertical;
              
            const horizontalURL = catalog.thumbnailHorizontal.startsWith('https://cdn.biblecms.com')
              ? '/uploads/' + catalog.thumbnailHorizontal.split('/').pop()
              : catalog.thumbnailHorizontal;
            const coverFallback = '/uploads/sample_vertical.jpg';
            const bannerFallback = '/uploads/sample_horizontal.jpg';

            const viewText = currentLang === 'tr' ? 'Görüntüle' : 'View';

            rows += `
              <tr>
                <td><span class="badge badge-dark">${catalog.id}</span></td>
                <td><strong>${catalog.name}</strong></td>
                <td><span class="text-secondary small">${catalog.description}</span></td>
                <td class="text-center">
                  <img src="${verticalURL}" class="img-thumbnail preview-trigger" style="max-height: 55px; object-fit: contain; cursor: pointer;" data-title="${catalog.name} - Cover" href="${verticalURL}" onerror="this.onerror=null;this.src='${coverFallback}'">
                  <br>
                  <a href="${verticalURL}" class="btn btn-xs btn-link text-info mt-1 preview-trigger" data-title="${catalog.name} - Cover"><i class="fas fa-expand"></i> ${viewText} Cover</a>
                </td>
                <td class="text-center">
                  <img src="${horizontalURL}" class="img-thumbnail preview-trigger" style="max-height: 55px; object-fit: contain; cursor: pointer;" data-title="${catalog.name} - Banner" href="${horizontalURL}" onerror="this.onerror=null;this.src='${bannerFallback}'">
                  <br>
                  <a href="${horizontalURL}" class="btn btn-xs btn-link text-info mt-1 preview-trigger" data-title="${catalog.name} - Banner"><i class="fas fa-expand"></i> ${viewText} Banner</a>
                </td>
                <td><small class="text-muted"><i class="far fa-calendar-alt mr-1"></i> ${date}</small></td>
              </tr>
            `;
          });
          
          $('#catalogsTableBody').html(rows);

          // Build localization settings for DataTables
          const trLangConfig = {
            "search": "Ara:",
            "lengthMenu": "_MENU_ kayıt göster",
            "info": "_TOTAL_ kayıttan _START_ - _END_ arası gösteriliyor",
            "infoEmpty": "Kayıt yok",
            "infoFiltered": "(_MAX_ kayıt içerisinden filtrelendi)",
            "zeroRecords": "Eşleşen kayıt bulunamadı",
            "paginate": {
              "first": "İlk",
              "last": "Son",
              "next": "Sonraki",
              "previous": "Önceki"
            }
          };

          const enLangConfig = {
            "search": "Search:",
            "lengthMenu": "Show _MENU_ entries",
            "info": "Showing _START_ to _END_ of _TOTAL_ entries",
            "infoEmpty": "Showing 0 to 0 of 0 entries",
            "infoFiltered": "(filtered from _MAX_ total entries)",
            "zeroRecords": "No matching records found",
            "paginate": {
              "first": "First",
              "last": "Last",
              "next": "Next",
              "previous": "Previous"
            }
          };

          // Initialize DataTable with settings
          $('#catalogsTable').DataTable({
            "responsive": true,
            "lengthChange": true,
            "autoWidth": false,
            "pageLength": 5,
            "lengthMenu": [5, 10, 25, 50],
            "language": currentLang === 'tr' ? trLangConfig : enLangConfig
          });
        },
        error: function(xhr) {
          console.error('Failed to load catalogs', xhr);
        }
      });
    }

    // Add Catalog Form Submission (Multipart)
    $('#addCatalogForm').submit(function(e) {
      e.preventDefault();
      
      const submitBtn = $('#submitBtn');
      const savingText = currentLang === 'tr' ? 'Yükleniyor...' : 'Uploading...';
      submitBtn.attr('disabled', true).html(`<i class="fas fa-spinner fa-spin mr-1"></i> ${savingText}`);

      const formData = new FormData();
      formData.append('name', $('#catalogName').val());
      formData.append('description', $('#catalogDescription').val());
      formData.append('verticalImage', $('#verticalImage')[0].files[0]);
